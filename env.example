# Telegram Settings
TELEGRAM_TOKEN=your_telegram_bot_token_here
ALLOWED_TELEGRAM_ID=123456789

# Bybit API Settings
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# Trading Settings
IS_DEMO=True
USER_RISK_USD=50

# Margin safety buffers
MARGIN_BUFFER_USD=1.0
MARGIN_BUFFER_PCT=0.03

# =========================
# OPTIONAL FEATURES
# =========================

# --- Market подтверждение (защита от мисклика)
# 0 = как раньше (GO MARKET сразу исполняет)
# 1 = сначала preview, потом Confirm/Cancel
REQUIRE_MARKET_CONFIRM=0
# TTL контекста preview в секундах (после истечения confirm недействителен)
MARKET_PREVIEW_TTL_SEC=300


# --- Account Risk Budget / HEAT (суммарный риск по стопам)
# 0 = отключено
# >0 = лимит суммарного "риска на стоп" в USDT по открытым/планируемым сделкам
MAX_TOTAL_HEAT_USDT=0
# reject = отклонять новые сделки при превышении heat
# queue  = складывать в очередь (если включено; авто-исполнение может быть не включено)
HEAT_ACTION=reject
# TTL очереди в минутах
HEAT_QUEUE_TTL_MIN=30


# --- Конфликты сигналов по одному символу
# ignore = если уже есть позиция/вход по этому символу в том же направлении — игнорировать новый сигнал
# add_if_allowed = разрешать добор (только если SOURCE_ALLOW_ADD=1 и heat позволяет)
CONFLICT_POLICY_SAME_DIR=ignore
# 0 = запрет доборов (default)
# 1 = разрешить доборы (вместе с CONFLICT_POLICY_SAME_DIR=add_if_allowed)
SOURCE_ALLOW_ADD=0
# Противоположное направление (LONG vs SHORT по одному символу) — всегда блокируется (fail-closed)


# --- Auto-quarantine источников (включать после накопления статистики)
# Отключено, если пороги PnL = 0 и т.п.
# После N убыточных сделок подряд источник выключается для новых сигналов
QUARANTINE_LOSS_STREAK=3
# Если дневной PnL источника <= порога -> quarantine (0 = отключено)
QUARANTINE_DAILY_PNL_USDT=0
# Если недельный PnL источника <= порога -> quarantine (0 = отключено)
QUARANTINE_WEEKLY_PNL_USDT=0