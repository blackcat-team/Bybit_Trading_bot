# ─────────────────────────────────────────────────────────────────────────────
# Bybit Telegram Trading Bot — шаблон переменных окружения
# Скопируйте файл в .env и заполните своими значениями.
# ВАЖНО: файл .env должен быть сохранён в кодировке UTF-8 (без BOM).
# ─────────────────────────────────────────────────────────────────────────────

# ── ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ ───────────────────────────────────────────────────
TELEGRAM_TOKEN=токен_вашего_telegram_бота
BYBIT_API_KEY=ваш_api_key_bybit
BYBIT_API_SECRET=ваш_api_secret_bybit
# Только ваш личный Telegram ID (не группа, не канал).
# Узнать через @userinfobot.
ALLOWED_TELEGRAM_ID=ваш_telegram_id

# ── РЕЖИМ ТОРГОВЛИ ───────────────────────────────────────────────────────────
# IS_DEMO=True  → тестовая сеть Bybit (бумажная торговля, безопасно)
# IS_DEMO=False → реальный счёт (mainnet)
IS_DEMO=True

# ── ПАРАМЕТРЫ РИСКА ──────────────────────────────────────────────────────────
# Фиксированный риск на сделку в USDT.
# Пример: 50 — при срабатывании стопа потеря составит ≈50$.
USER_RISK_USD=50

# Буферы маржи для защиты от ошибки 110007 (insufficient margin).
MARGIN_BUFFER_USD=1.0     # Абсолютный запас в $ (вычитается из доступной маржи)
MARGIN_BUFFER_PCT=0.03    # Относительный запас, 3% от ноционала позиции

# ── КОНТРОЛЬ СУММАРНОГО РИСКА (HEAT) ─────────────────────────────────────────
# MAX_TOTAL_HEAT_USDT — сумма риска-до-стопа по всем открытым позициям.
# 0 = отключено (по умолчанию).
# Пример: 200 — новые сделки блокируются, пока суммарный риск превышает $200.
MAX_TOTAL_HEAT_USDT=0

# Действие при превышении heat-лимита:
#   reject — блокировать сделку немедленно (fail-closed, по умолчанию)
#   queue  — сохранить сигнал в очередь на срок до HEAT_QUEUE_TTL_MIN минут.
#            ВНИМАНИЕ: автоматического исполнения нет — сигнал только хранится.
#            Исполнение из очереди требует реализации воркера.
HEAT_ACTION=reject

# Время жизни сигнала в очереди (только при HEAT_ACTION=queue).
HEAT_QUEUE_TTL_MIN=30

# ── ПОЛИТИКА КОНФЛИКТА СИГНАЛОВ ───────────────────────────────────────────────
# Что делать, если новый сигнал пришёл по символу, у которого уже есть
# открытая позиция или ожидающий ордер на вход в том же направлении.
#   ignore         — тихо отбросить дубль (по умолчанию, безопасно)
#   add_if_allowed — разрешить добор, если SOURCE_ALLOW_ADD=1 и heat позволяет
CONFLICT_POLICY_SAME_DIR=ignore

# Разрешить добор к существующей позиции того же направления.
# Используется только при CONFLICT_POLICY_SAME_DIR=add_if_allowed.
# 0 = запрещено (по умолчанию), 1 = разрешено
SOURCE_ALLOW_ADD=0

# ── АВТОКАРАНТИН ИСТОЧНИКОВ СИГНАЛОВ ─────────────────────────────────────────
# Автоматически отключить источник после N убыточных сделок подряд.
# 0 = отключено (по умолчанию). Рекомендуется: 3–5.
QUARANTINE_LOSS_STREAK=0

# Отключить источник, если дневной PnL (USDT) упал ниже порога.
# 0 = отключено. Отрицательное значение = разрешить убыток до указанной суммы.
QUARANTINE_DAILY_PNL_USDT=0

# То же самое, но за недельное окно.
QUARANTINE_WEEKLY_PNL_USDT=0

# ── ПОДТВЕРЖДЕНИЕ МАРКЕТ-ВХОДА (PREVIEW) ─────────────────────────────────────
# 0 = стандартное поведение: один тап → немедленное исполнение (по умолчанию)
# 1 = первый тап показывает превью сделки; исполнение — только после CONFIRM.
#     Рекомендуется на живом счёте.
REQUIRE_MARKET_CONFIRM=0

# Время жизни кнопки CONFIRM после показа превью (секунды).
MARKET_PREVIEW_TTL_SEC=300

# ── ДИАГНОСТИКА ───────────────────────────────────────────────────────────────
# Логировать WARNING (вместо DEBUG) когда вызов Bybit API занимает > 0.5 с.
# 1 = включить, оставьте пустым или 0 = отключить (по умолчанию, тихие логи).
BYBIT_SLOW_CALL_WARN=
