# ─────────────────────────────────────────────
# Bybit Telegram Trading Bot — environment vars
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
ALLOWED_TELEGRAM_ID=your_telegram_user_id

# ── TRADING MODE ─────────────────────────────
# IS_DEMO=True   → testnet (paper trading)
# IS_DEMO=False  → live (mainnet)
IS_DEMO=True

# ── RISK PARAMETERS ──────────────────────────
# Fixed risk per trade in USDT (default 50)
USER_RISK_USD=50

# Margin safety buffers to avoid Bybit error 110007
MARGIN_BUFFER_USD=1.0     # Flat dollar reserve
MARGIN_BUFFER_PCT=0.03    # 3% of notional reserve

# ── SIGNAL CONFLICT POLICY ────────────────────
# What to do when a new signal arrives for a symbol that already has a
# position or pending entry order in the same direction.
#   ignore         — silently drop the duplicate (default, safe)
#   add_if_allowed — allow adding to the position if SOURCE_ALLOW_ADD=1
CONFLICT_POLICY_SAME_DIR=ignore

# Allow adding to an existing same-direction position.
# Only used when CONFLICT_POLICY_SAME_DIR=add_if_allowed.
# 0 = disabled (default), 1 = enabled
SOURCE_ALLOW_ADD=0

# ── RISK BUDGET / HEAT ────────────────────────
# Total open risk ceiling across all positions (sum of risk-at-stop in USDT).
# 0 = disabled (default). Example: 200 blocks new trades when risk exceeds $200.
MAX_TOTAL_HEAT_USDT=0

# What to do when the heat limit is reached:
#   reject — fail-closed, block the trade (default)
#   queue  — park the trade up to HEAT_QUEUE_TTL_MIN, retry when heat drops
HEAT_ACTION=reject

# How long (minutes) a queued trade stays valid before being discarded.
HEAT_QUEUE_TTL_MIN=30

# ── MARKET TRADE PREVIEW / CONFIRM ───────────
# 0 (default) = one-tap GO MARKET, executed immediately.
# 1 = first tap shows a preview card; user must confirm within TTL seconds.
REQUIRE_MARKET_CONFIRM=0

# Seconds the confirm button stays valid after the preview is shown.
MARKET_PREVIEW_TTL_SEC=300

# ── SOURCE QUARANTINE ─────────────────────────
# Automatically disable a signal source after N consecutive losses.
# 0 = disabled (default).
QUARANTINE_LOSS_STREAK=0

# Disable a source if its daily PnL (USDT) falls below this threshold.
# 0 = disabled (default). Negative = allow losses down to that amount.
QUARANTINE_DAILY_PNL_USDT=0

# Same as above, but evaluated over the current week.
QUARANTINE_WEEKLY_PNL_USDT=0

# ── DIAGNOSTICS ───────────────────────────────
# Log a WARNING (instead of DEBUG) when a Bybit API call exceeds 0.5 s.
# 1 = enabled, leave empty or 0 = disabled (default, quieter logs).
BYBIT_SLOW_CALL_WARN=
